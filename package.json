{
  "name": "copilot-chat-sync",
  "displayName": "Copilot Chat Sync",
  "description": "Automatically sync GitHub Copilot chat history to a GitHub repository",
  "version": "0.4.0",
  "publisher": "yuzuan",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilotChatSync",
          "title": "Copilot Chat History",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "copilotChatSync": [
        {
          "id": "copilotChatSync.sessions",
          "name": "Chat Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "copilotChatSync.syncNow",
        "title": "Copilot Chat Sync: Sync Now"
      },
      {
        "command": "copilotChatSync.exportAll",
        "title": "Copilot Chat Sync: Export All Sessions"
      },
      {
        "command": "copilotChatSync.configure",
        "title": "Copilot Chat Sync: Configure Repository"
      },
      {
        "command": "copilotChatSync.search",
        "title": "Copilot Chat Sync: Search Chat History"
      },
      {
        "command": "copilotChatSync.refreshSessions",
        "title": "Copilot Chat Sync: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "copilotChatSync.previewSession",
        "title": "Preview Session"
      },
      {
        "command": "copilotChatSync.exportSession",
        "title": "Export Session"
      },
      {
        "command": "copilotChatSync.exportQA",
        "title": "Copilot Chat Sync: Export Q&A Archive"
      },
      {
        "command": "copilotChatSync.exportChunks",
        "title": "Copilot Chat Sync: Export as Chunks"
      },
      {
        "command": "copilotChatSync.importHtml",
        "title": "Copilot Chat Sync: Import from HTML"
      },
      {
        "command": "copilotChatSync.copyToClipboard",
        "title": "Copy to Clipboard"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "copilotChatSync.refreshSessions",
          "when": "view == copilotChatSync.sessions",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "copilotChatSync.previewSession",
          "when": "view == copilotChatSync.sessions && viewItem == session"
        },
        {
          "command": "copilotChatSync.exportSession",
          "when": "view == copilotChatSync.sessions && viewItem == session"
        },
        {
          "command": "copilotChatSync.copyToClipboard",
          "when": "view == copilotChatSync.sessions && viewItem == session"
        }
      ]
    },
    "configuration": {
      "title": "Copilot Chat Sync",
      "properties": {
        "copilotChatSync.repoPath": {
          "type": "string",
          "default": "",
          "description": "Local path to the git repository for syncing chat history"
        },
        "copilotChatSync.remoteUrl": {
          "type": "string",
          "default": "",
          "description": "GitHub remote URL (e.g. https://github.com/user/repo.git)"
        },
        "copilotChatSync.autoSync": {
          "type": "boolean",
          "default": true,
          "description": "Automatically sync when chat sessions change"
        },
        "copilotChatSync.syncIntervalMinutes": {
          "type": "number",
          "default": 5,
          "description": "Auto-sync interval in minutes"
        },
        "copilotChatSync.includeToolCalls": {
          "type": "boolean",
          "default": false,
          "description": "Include tool call details in exported Markdown"
        },
        "copilotChatSync.defaultExportFormat": {
          "type": "string",
          "default": "markdown",
          "enum": ["markdown", "json", "html"],
          "description": "Default export format for chat sessions"
        },
        "copilotChatSync.maxSessionsInView": {
          "type": "number",
          "default": 100,
          "description": "Maximum sessions shown in sidebar"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.0.0"
  }
}
